@startuml Diagrama_Dominio_Unificado_Condominio
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

skinparam class {
    BackgroundColor #E8F1FF
    BorderColor #2F5EA8
    ArrowColor #2F5EA8
    FontColor #1F3F73
}
skinparam enum {
    BackgroundColor #EEF5FF
    BorderColor #1F3F73
    FontColor #1F3F73
}


title Diagrama de Clases de Dominio Unificado - Sistema de Gestión de Condominios

' ==========================================
' GRB: GESTIÓN DE USUARIOS (NÚCLEO)
' ==========================================
package "GRB - Usuarios y Accesos" {
    class Usuario {
        - idUsuario: UUID
        - identificacion: String
        - nombre: String
        - apellido: String
        - correo: String
        - telefono: String
        + consultarDatos(): Map
        + actualizarPerfil(datos: Map): void
    }

    class Cuenta {
        - contrasena: String
        - estado: EstadoCuenta
        - fechaCreacion: Date
        + activar(): void
        + desactivar(): void
    }

    class Rol {
        - nombre: NombreRol
        - descripcion: String
    }

    enum EstadoCuenta {
        ACTIVA
        DESACTIVADA
    }

    enum NombreRol {
        ADMINISTRADOR
        PRESIDENTE
        RESIDENTE
        PROPIETARIO
        SEGURIDAD
    }

    Usuario "1" *-- "1" Cuenta : "posee >"
    Cuenta "*" -- "*" Rol : "tiene asignado >"
}

' ==========================================
' GRC: GESTIÓN DE INMUEBLES
' ==========================================
package "GRC - Inmuebles" {
    abstract class Inmueble {
        - idInmueble: UUID
        - codigo: String
        - estado: String
    }

    abstract class UnidadPrivada {
        - alicuotaBase: double
        - enAlquiler: boolean
    }

    class Departamento {
        - numero: int
        - piso: int
    }
    
    class Suite {
        - tieneBalcon: boolean
    }

    class Caracteristica {
        - areaMetrosCuadrados: double
        - numeroHabitaciones: int
        - numeroBanos: int
    }

    abstract class EspacioComun {
        - nombre: String
        - aforoMaximo: int
        - requiereGarantia: boolean
        + estaDisponible(fecha: Date, inicio: Time, fin: Time): boolean
    }

    class SalonDeEventos {
        - costoReserva: double
    }

    class AreaRecreacional {
        - requiereEquipamiento: boolean
    }

    class Parqueadero {
        - numero: String
        - tipo: TipoParqueadero
    }

    enum TipoParqueadero {
        PRIVADO
        VISITA
    }

    Inmueble <|-- UnidadPrivada
    Inmueble <|-- EspacioComun
    Inmueble "1" *-- "1" Caracteristica : "descrito por >"
    
    UnidadPrivada <|-- Departamento
    UnidadPrivada <|-- Suite
    
    EspacioComun <|-- SalonDeEventos
    EspacioComun <|-- AreaRecreacional
    EspacioComun <|-- Parqueadero

    ' Relaciones de Ocupación y Propiedad
    Usuario "*" -- "*" UnidadPrivada : "es Propietario de >"
    Usuario "1" -- "*" UnidadPrivada : "habita como Residente >"
}

' ==========================================
' GRA: PAGOS Y FINANZAS
' ==========================================
package "GRA - Finanzas" {
    class Deuda {
        - idDeuda: UUID
        - motivo: MotivoDeuda
        - valor: double
        - fechaMaxima: Date
        - estado: EstadoDeuda
        + aplicarMora(porcentaje: double): void
    }

    class Pago {
        - idPago: UUID
        - fecha: Date
        - metodo: MetodoPago
        - comprobante: String
        - valorPagado: double
    }

    enum EstadoDeuda {
        PENDIENTE, PAGADA, MORA, ANULADA
    }

    enum MotivoDeuda {
        ALICUOTA, MULTA, RESERVA, EXTRAORDINARIA
    }
    
    enum MetodoPago {
        EFECTIVO, TRANSFERENCIA, TARJETA
    }

    Usuario "1" --> "*" Deuda : "es responsable de >"
    Deuda "*" --> "0..1" UnidadPrivada : "asociada a >"
    Deuda "1" *-- "0..*" Pago : "se liquida con >"
}

' ==========================================
' GRD: RESERVAS
' ==========================================
package "GRD - Reservas" {
    class Reserva {
        - idReserva: UUID
        - fechaReserva: Date
        - horaInicio: Time
        - horaFin: Time
        - estado: EstadoReserva
        + cancelar(): void
    }

    enum EstadoReserva {
        PENDIENTE, CONFIRMADA, CANCELADA, FINALIZADA
    }

    Usuario "1" --> "*" Reserva : "solicita >"
    Reserva "*" --> "1" EspacioComun : "asigna >"
}

' ==========================================
' GRE: SEGURIDAD Y CHECK-IN
' ==========================================
package "GRE - Seguridad" {
    class Visitante {
        - identificacion: String
        - nombre: String
        - placaVehiculo: String
    }

    class VisitaProgramada {
        - fechaHora: Date
        - motivo: String
        - estado: EstadoVisita
    }

    class RegistroEntrada {
        - fechaHoraLlegada: Date
        - tipoEntrada: String
        - observaciones: String
    }

    enum EstadoVisita {
        PROGRAMADA, EN_CURSO, FINALIZADA, CANCELADA
    }

    Usuario "1" --> "*" VisitaProgramada : "autoriza >"
    VisitaProgramada "*" --> "1" Visitante : "espera a >"
    VisitaProgramada "0..1" <-- "1" RegistroEntrada : "valida <"
    Usuario "1" --> "*" RegistroEntrada : "registra en garita >"
}

' ==========================================
' GRF: COMUNICACIÓN Y ALERTAS
' ==========================================
package "GRF - Comunicación" {
    class Comunicacion {
        - asunto: String
        - contenido: String
        - fechaEnvio: Date
        - tipo: TipoComunicacion
    }

    class AlertaEmergencia {
        - nivelPrioridad: String
        - latitud: double
        - longitud: double
    }

    enum TipoComunicacion {
        ANUNCIO_GENERAL, MENSAJE_DIRECTO, REPORTE
    }

    Comunicacion <|-- AlertaEmergencia
    Usuario "1" --> "*" Comunicacion : "emite >"
    Comunicacion "*" --> "*" Usuario : "dirigida a (Destinatarios) >"
}

@enduml