@startuml DomainClassDiagram
skinparam classAttributeIconSize 0
skinparam linetype ortho

' ==========================================
' CLASE ABSTRACTA PADRE (INMUEBLE)
' ==========================================
abstract class Inmueble {
    - idInmueble : int
    - codigo : String
    - estado: EstadoInmueble
    - areaMetrosCuadrados: double
    - descripcion: String

    + {abstract} registrar()
    + actualizarEstado(nuevoEstado: EstadoInmueble)
    + {abstract} consultar()
}

enum EstadoInmueble {
    DISPONIBLE
    OCUPADO
    EN_MANTENIMIENTO
    EN_REMODELACION
    VENDIDO
}

' ==========================================
' CLASES HIJAS (Jerarquía de Inmueble)
' ==========================================
class Departamento {
    - numeroDepartamento: int
    - piso: int
    - numeroHabitaciones: int
    - numeroBanos: int
    - disponibleAlquiler: boolean
    - disponibleVenta: boolean
}

class Suite {
    - numeroHabitaciones: int
    - numeroBanos: int
    - tieneBalcon: boolean
    - disponibleAlquiler: boolean
    - disponibleVenta: boolean
}

abstract class EspacioComun {
    # id: String
    # nombre: String
    # aforoMaximo: int
    + estaDisponible(fecha: Date, inicio: Time, fin: Time): boolean
}

class SalonDeEventos {
    - costoReserva: Double
    - requiereGarantia: boolean
}

class AreaRecreacional {
    - tipoCancha: String
    - requiereEquipamiento: boolean
}

class Parqueadero {
    - idParqueadero : int
    - nombre: String 

    + calcularPlazasDisponibles()
    + consultarPlazas()
}

' ==========================================
' PLAZAS
' ==========================================
abstract class Plaza {
    - numeroPlaza: String
    - disponible:boolean
   
    + {abstract} verificarPermiso(): boolean
    + obtenerTiempoMaximo(): int
}

class PlazaPropietario {

    + verificarPermiso(): boolean
    + obtenerTiempoMaximo(): int
}

class PlazaVisita {
    - tiempoMaximo: int

    + verificarPermiso(): boolean
    + obtenerTiempoMaximo(): int
}

' ==========================================
' HERENCIAS
' ==========================================
Inmueble <|-- Departamento
Inmueble <|-- Suite
Inmueble <|-- EspacioComun
Inmueble <|-- Parqueadero

EspacioComun <|-- SalonDeEventos
EspacioComun <|-- AreaRecreacional

Plaza <|-- PlazaPropietario
Plaza <|-- PlazaVisita

' ==========================================
' COMPOSICIÓN
' ==========================================
Parqueadero "1" *-- "0..*" Plaza : "contiene"

' ==========================================
' COMPONENTES Y GESTIÓN
' ==========================================
class CatalogoCondominio{
    - idCatalogo : int
    - fechaActualizacion : Date
    - listaInmuebles: List<Inmueble>

    + agregarInmueble()
    + eliminarInmueble()
    + actualizarCatalogo()
    + consultarCatalogo()
    + calcularCantidadPlazasVisita()

}

class ReporteCambio {
    - idReporte : int
    - fechaGeneracion : Date
    - descripcionCambio : String

    + registrarCambio(descripcion: String)
    + consultarReporte() 
}

class Propiedad {
    - idPropiedad : int
    - enAlquiler : boolean
    - fechaRegistro : Date

    + consultarPropiedad()
    + actualizarPropietario()
    + actualizarEstadoAlquiler()
}

class CasoFortuito {
    - idCaso : int
    - descripcion : String
    - fecha : Date
    - estado : EstadoCaso

    + registrarCaso(descripcion: String)
    + actualizarCaso(estado: EstadoCaso)
    + cerrarCaso()
}

enum EstadoCaso {
    REPORTADO
    EN_PROCESO
    RESUELTO
}

' ==========================================
' DEPENDENCIAS CON ENUMS (ESTILO GRD/GRE/GRF)
' ==========================================
Inmueble .down.> EstadoInmueble : <<use>>
CasoFortuito .down.> EstadoCaso : <<use>>

' ==========================================
' DISPOSICIÓN DE RELACIONES
' ==========================================
CatalogoCondominio "1" o-right- "*" Inmueble
Inmueble "1" --> "*" ReporteCambio
Inmueble "1" --> "*" CasoFortuito : "registra"

Propiedad "*" --> "1" Inmueble : "asociada a"
PlazaPropietario "*" --> "1" Propiedad : "asignada a"
@enduml
