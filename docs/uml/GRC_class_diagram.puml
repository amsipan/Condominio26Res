@startuml

class Usuario
class Residente
class Presidente
class Administrador

Usuario <|-- Residente
Usuario <|-- Presidente
Usuario <|-- Administrador

' ==========================================
' CLASE PADRE
' ==========================================
class Inmueble {
- idInmueble : int
- codigo : String
- estado : String
- disponibleAlquiler : boolean
- disponibleVenta : boolean

+ registrar()
+ actualizarEstado()
+ consultar()
}

' ==========================================
' CLASES HIJAS (Herencia de Inmueble)
' ==========================================
class Edificio {
- idEdificio : int
- nombre : String
- direccion : String
- numeroPisos : int

+ registrar()
+ modificar()
+ eliminar()
+ consultar()
}

class Departamento {
- numeroDepartamento : int
- piso : int
- nroHabitaciones : int
}

class Suite {
- tieneBalcon : boolean
}

class EspacioComun {
- nombreEspacio : String
- reglamentoUso : String
}

class Parqueadero {
- idParqueadero : int
- numero : String
- disponible : boolean

+ registrar()
+ consultar()
+ actualizarDisponibilidad()
}

' Relaciones de Herencia
Inmueble <|-- Edificio
Inmueble <|-- Departamento
Inmueble <|-- Suite
Inmueble <|-- EspacioComun
Inmueble <|-- Parqueadero

' ==========================================
' RESTO DE CLASES INTACTAS
' ==========================================
class CatalogoCondominio {
- idCatalogo : int
- fechaActualizacion : Date

+ agregarInmueble()
+ eliminarInmueble()
+ actualizarCatalogo()
+ consultarCatalogo()
}

class CaracteristicaInmueble {
- idCaracteristica : int
- areaMetrosCuadrados : double
- numeroHabitaciones : int
- numeroBanos : int
- numeroParqueaderos : int
- descripcion : String

+ registrarCaracteristicas()
+ modificarCaracteristicas()
+ consultarCaracteristicas()
}

class Propiedad {
- idPropiedad : int
- enAlquiler : boolean
- fechaRegistro : Date

+ consultarPropiedad()
+ consultarResidentes()
+ actualizarEstadoAlquiler()
}

class CasoFortuito {
- idCaso : int
- tipo : String
- descripcion : String
- fecha : Date
- estado : String

+ registrarCaso()
+ actualizarCaso()
+ cerrarCaso()
}

class Notificacion {

}

class ReporteCambio {
- idReporte : int
- fechaGeneracion : Date
- tipoCambio : String
- descripcionCambio : String

+ registrarCambio()
+ generarReporte()
+ consultarReporte()
}

' ==========================================
' RELACIONES ORIGINALES CORREGIDAS
' ==========================================
CatalogoCondominio "1" o-- "*" Inmueble

Inmueble "1" *-- "1" CaracteristicaInmueble

Propiedad "*" --> "1" Inmueble

Propiedad "*" --> "1" Usuario

Propiedad "1" --> "*" Residente

Inmueble "1" --> "*" ReporteCambio

CasoFortuito "1" --> "*" Notificacion

Inmueble "1" --> "*" CasoFortuito

@enduml