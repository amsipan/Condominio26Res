@startuml Diagrama_Dominio_GRF

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle

title Diagrama de Dominio - Módulo GRF: Comunicación

package "Entidades del Dominio - Módulo GRF" {

    enum TipoComunicacion {
        MENSAJE_RESIDENTES
        COMUNICADO_TRABAJADORES
        MENSAJE_GLOBAL
        ANUNCIO_GENERAL
    }

    enum EstadoComunicacion {
        CREADA
        ENVIADA
        FALLIDA
        ELIMINADA
    }

    enum AccionHistorial {
        CREACION
        ENVIO
        MODIFICACION
        ELIMINACION
        NOTIFICACION
    }

    class Destinatario <<Partial GRB>> {
        - idUsuario: String
        - nombre: String
        - rol: String
    }

    class Comunicacion {
        - idComunicacion: String
        - asunto: String
        - contenido: String
        - fechaCreacion: Date
        - fechaEnvio: Date
        - tipo: TipoComunicacion
        - estado: EstadoComunicacion
        + validarContenido(): boolean
        + marcarComoEnviada(): void
        + marcarComoFallida(): void
    }

    class MensajeResidentes {
        - residentesDestino: List<Destinatario>
        + seleccionarResidentes(destinatarios: List<Destinatario>): void
    }

    class ComunicadoTrabajadores {
        - trabajadoresDestino: List<Destinatario>
        + seleccionarTrabajadores(destinatarios: List<Destinatario>): void
    }

    class MensajeGlobal {
        + seleccionarTodosLosUsuarios(): void
    }

    class AnuncioGeneral {
        - idAnuncio: String
        - titulo: String
        - contenido: String
        - fechaPublicacion: Date
        - fechaModificacion: Date
        - activo: boolean
        + publicar(): void
        + modificar(datos: Map): void
        + eliminar(): void
    }

    class Notificacion {
        - idNotificacion: String
        - fechaEnvio: Date
        - destinatario: Destinatario
        + generar(): void
    }

    class HistorialComunicacion {
        - idHistorial: String
        - fechaRegistro: Date
        - accion: AccionHistorial
        - detalle: String
        + registrarAccion(): void
    }

    class ReporteComunicacion {
        - idReporte: String
        - fechaGeneracion: Date
        - filtros: Map
        + generar(): void
    }

    Comunicacion <|-- MensajeResidentes
    Comunicacion <|-- ComunicadoTrabajadores
    Comunicacion <|-- MensajeGlobal

    Comunicacion ..> TipoComunicacion : usa
    Comunicacion ..> EstadoComunicacion : usa
    HistorialComunicacion ..> AccionHistorial : usa

    MensajeResidentes "1" --> "1..*" Destinatario : dirigido a >
    ComunicadoTrabajadores "1" --> "1..*" Destinatario : dirigido a >
    MensajeGlobal "1" --> "0..*" Destinatario : dirigido a >

    Comunicacion "1" --> "0..*" Notificacion : genera >
    Comunicacion "1" --> "1..*" HistorialComunicacion : registra >
    AnuncioGeneral "1" --> "0..*" Notificacion : genera >
    AnuncioGeneral "1" --> "1..*" HistorialComunicacion : registra >
    ReporteComunicacion ..> HistorialComunicacion : consulta >
}

@enduml