@startuml C4_Class_Diagram_GRF_Diseno

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 70

title Diseño Arquitectónico - Módulo GRF: Comunicación

package "Controladores (JavaFX)" #DDEEFF {
    class ControladorMensajes {
        - servicioMensajes: ServicioMensajes
        + enviarMensajeAResidentesUI(): void
        + enviarComunicadoATrabajadoresUI(): void
        + enviarMensajeGlobalUI(): void
    }

    class ControladorAnuncios {
        - servicioAnuncios: ServicioAnuncios
        + crearAnuncioGeneralUI(): void
        + modificarAnuncioGeneralUI(): void
        + eliminarAnuncioGeneralUI(): void
    }

    class ControladorReportes {
        - servicioReportes: ServicioReportes
        + crearReporteComunicacionUI(): void
    }

    class ControladorHistorial {
        - servicioHistorial: ServicioHistorial
        + consultarHistorialDeMensajesUI(): void
    }
}

package "Servicios (Lógica de Casos de Uso)" #DDFFDD {
    class ServicioMensajes {
        - repoComunicaciones: RepositorioComunicaciones
        - servicioHistorial: ServicioHistorial
        - servicioNotificaciones: ServicioNotificaciones
        + enviarMensajeAResidentes(asunto: String, contenido: String, destinatarios: List<String>): void
        + enviarComunicadoATrabajadores(asunto: String, contenido: String, destinatarios: List<String>): void
        + enviarMensajeGlobal(asunto: String, contenido: String): void
    }

    class ServicioAnuncios {
        - repoAnuncios: RepositorioAnuncios
        - servicioHistorial: ServicioHistorial
        - servicioNotificaciones: ServicioNotificaciones
        + crearAnuncioGeneral(titulo: String, contenido: String): void
        + modificarAnuncioGeneral(idAnuncio: String, datos: Map): void
        + eliminarAnuncioGeneral(idAnuncio: String): void
    }

    class ServicioReportes {
        - servicioHistorial: ServicioHistorial
        + crearReporteComunicacion(filtros: Map): ReporteComunicacion
    }

    class ServicioHistorial {
        - repoHistorial: RepositorioHistorial
        + registrarComunicacion(comunicacion: Comunicacion): void
        + consultarHistorial(filtros: Map): List<HistorialComunicacion>
    }

    class ServicioNotificaciones {
        - repoNotificaciones: RepositorioNotificaciones
        + notificarMensajeRecibido(comunicacion: Comunicacion): void
    }
}

package "Repositorios (DAO)" #FFEECC {
    interface RepositorioComunicaciones {
        + guardar(comunicacion: Comunicacion): void
        + actualizar(comunicacion: Comunicacion): void
        + buscarPorId(idComunicacion: String): Comunicacion
        + buscarPorFiltros(filtros: Map): List<Comunicacion>
    }

    interface RepositorioAnuncios {
        + guardar(anuncio: AnuncioGeneral): void
        + actualizar(anuncio: AnuncioGeneral): void
        + eliminar(idAnuncio: String): void
        + buscarPorId(idAnuncio: String): AnuncioGeneral
    }

    interface RepositorioHistorial {
        + guardar(historial: HistorialComunicacion): void
        + buscarPorFiltros(filtros: Map): List<HistorialComunicacion>
    }

    interface RepositorioNotificaciones {
        + guardar(notificacion: Notificacion): void
        + buscarPorComunicacion(idComunicacion: String): List<Notificacion>
    }
}

package "Entidades (Dominio)" #FFE0E0 {
    class Comunicacion {
        - idComunicacion: String
        - asunto: String
        - contenido: String
        - fechaCreacion: Date
        - fechaEnvio: Date
    }

    class AnuncioGeneral {
        - idAnuncio: String
        - titulo: String
        - contenido: String
        - fechaPublicacion: Date
        - activo: boolean
    }

    class HistorialComunicacion {
        - idHistorial: String
        - fechaRegistro: Date
        - detalle: String
    }

    class Notificacion {
        - idNotificacion: String
        - fechaEnvio: Date
    }

    class ReporteComunicacion {
        - idReporte: String
        - fechaGeneracion: Date
        - filtros: Map
    }
}

ControladorMensajes --> ServicioMensajes
ControladorAnuncios --> ServicioAnuncios
ControladorReportes --> ServicioReportes
ControladorHistorial --> ServicioHistorial

ServicioMensajes --> RepositorioComunicaciones
ServicioMensajes --> ServicioHistorial
ServicioMensajes --> ServicioNotificaciones

ServicioAnuncios --> RepositorioAnuncios
ServicioAnuncios --> ServicioHistorial
ServicioAnuncios --> ServicioNotificaciones

ServicioReportes --> ServicioHistorial
ServicioHistorial --> RepositorioHistorial
ServicioNotificaciones --> RepositorioNotificaciones

ServicioMensajes ..> Comunicacion
ServicioAnuncios ..> AnuncioGeneral
ServicioHistorial ..> HistorialComunicacion
ServicioNotificaciones ..> Notificacion
ServicioReportes ..> ReporteComunicacion

@enduml